{
  "name": "@jorg3l3on/zigzag",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "next dev --turbopack -p 3069",
    "build": "next build",
    "vercel-build": "node scripts/vercel-build.mjs",
    "start": "next start -p 3069",
    "lint": "eslint .",
    "seed": "tsx scripts/seed.ts",
    "seed:demo": "tsx scripts/seed-demo-company.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "migrate:deploy": "DATABASE_URL=${DIRECT_URL:-$DATABASE_URL} drizzle-kit migrate",
    "db:prod:setup": "DATABASE_URL=${DIRECT_URL:-$DATABASE_URL} drizzle-kit migrate && npm run seed",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:idor": "jest --runInBand --testNamePattern='cross-tenant IDOR|IDOR test fixtures|cross-tenant access \\(IDOR\\)'",
    "check:idor-coverage": "node scripts/check-idor-coverage.mjs",
    "test:e2e": "playwright test",
    "test:e2e:mobile": "playwright test --project=mobile-chrome",
    "test:e2e:visual": "playwright test --project=visual",
    "test:e2e:visual:update": "playwright test --project=visual --update-snapshots",
    "test:e2e:mobile-nav": "playwright test e2e/mobile-sticky-navbar.spec.ts --project=mobile-chrome --workers=1",
    "guides:capture": "node scripts/capture-onboarding-guide-screenshots.mjs",
    "guides:capture:prod": "GUIDES_BASE_URL=http://127.0.0.1:3070 node scripts/capture-onboarding-guide-screenshots.mjs",
    "lighthouse:mobile": "node scripts/mobile-lighthouse-baseline.mjs",
    "icons:generate": "node scripts/generate-pwa-icons.mjs",
    "rag:index": "ts-node -P rag/tsconfig.json rag/scripts/index-docs.ts",
    "rag:search": "ts-node -P rag/tsconfig.json rag/scripts/search.ts",
    "rag:ask": "ts-node -P rag/tsconfig.json rag/scripts/ask.ts"
  },
  "dependencies": {
    "@auth/core": "^0.39.1",
    "@hookform/resolvers": "^5.2.2",
    "@sentry/nextjs": "^10.62.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/react-table": "^8.21.3",
    "@types/bcryptjs": "^2.4.6",
    "@vercel/blob": "^0.27.3",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "html2canvas-pro": "^2.0.2",
    "html2pdf.js": "^0.14.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.13.0",
    "pg": "^8.20.0",
    "posthog-js": "^1.395.0",
    "posthog-node": "^5.21.2",
    "radix-ui": "1.4.3",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.75.0",
    "react-to-pdf": "^3.2.2",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.42.1",
    "@serwist/turbopack": "^9.5.11",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "msw": "^2.2.3",
    "postcss": "^8",
    "serwist": "^9.5.11",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.4",
    "to-ico": "^1.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
