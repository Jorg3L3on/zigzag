# ----------------------------------------
# Production environment variables template
# Target platforms: Vercel + Neon
# ----------------------------------------

# Neon PostgreSQL
# Use the pooled Neon URL for app runtime queries.
DATABASE_URL="postgresql://<user>:<password>@<pooled-host>/<database>?sslmode=verify-full&pgbouncer=true"

# Optional but recommended for migrations:
# Use Neon direct connection (non-pooled) for migrations.
DIRECT_URL="postgresql://<user>:<password>@<direct-host>/<database>?sslmode=verify-full"

# NextAuth
# Example: https://zigzag.vercel.app
NEXTAUTH_URL="https://<your-project>.vercel.app"
NEXTAUTH_SECRET="<generate-with-openssl-rand-base64-32>"

# Runtime
NODE_ENV="production"
