# Copy to `.env` and adjust values. Never commit `.env`.
#
# PostgreSQL: create the database first (e.g. `createdb zigzag`).
# Homebrew Postgres typically uses your macOS username and no password in the URL.

DATABASE_URL="postgresql://YOUR_USERNAME@localhost:5432/zigzag"
# Optional for production-style migration workflows.
DIRECT_URL="postgresql://YOUR_USERNAME@localhost:5432/zigzag"
NODE_ENV=development

# Connection pool sizing. On serverless each instance keeps its own pool, so
# point DATABASE_URL at a pooled endpoint (PgBouncer / Neon pooler) in prod and
# keep DB_POOL_MAX small. Optional; defaults: 5 in production, 10 in dev.
# DB_POOL_MAX=5
# DB_POOL_IDLE_MS=10000
# DB_POOL_CONNECT_MS=10000

NEXTAUTH_URL=http://localhost:3069
NEXTAUTH_SECRET=your-secret-key-here

# Vercel Blob — required for Company logo uploads (dashboard + API)
BLOB_READ_WRITE_TOKEN=

# Distributed rate limiting (no Redis). The distributed backend is Postgres
# (the `RateLimit` table); it is used automatically in production. Locally the
# app falls back to an in-memory limiter. Set RATE_LIMIT_BACKEND=postgres to use
# the Postgres backend in development too (requires the DB to be running).
# RATE_LIMIT_BACKEND=postgres

# Secret for the notifications cron endpoint (/api/cron/notifications).
# Vercel Cron sends it as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=

# Observability (optional). When SENTRY_DSN is unset, Sentry is disabled and the
# app logs structured JSON to the console only.
SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
#
# External uptime monitoring (configure in your provider, not in code): probe
# GET /api/health, /login, and /dashboard.
#
# Product analytics + feature flags (PostHog, free tier). All optional: when the
# keys are unset, analytics is disabled and feature flags fall back to defaults.
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Server-side capture/flags (defaults to the NEXT_PUBLIC_* values when unset):
# POSTHOG_KEY=
# POSTHOG_HOST=https://us.i.posthog.com

# Playwright E2E (authenticated specs)
E2E_EMAIL=
E2E_PASSWORD=
E2E_SYSTEM_EMAIL=jorge@jorge.com
# Optional overrides; default to E2E_PASSWORD (synced in e2e/global-setup.ts for seed users)
E2E_SYSTEM_PASSWORD=
E2E_VIEWER_EMAIL=viewer@test.com
E2E_VIEWER_PASSWORD=
# Optional: run Playwright against production build (recommended for auth-heavy specs)
# PLAYWRIGHT_USE_PROD=1 npm run test:e2e -- e2e/mobile-sticky-navbar.spec.ts
