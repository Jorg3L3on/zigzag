# Copy to `.env` and adjust values. Never commit `.env`.
#
# PostgreSQL: create the database first (e.g. `createdb zigzag`).
# Homebrew Postgres typically uses your macOS username and no password in the URL.

DATABASE_URL="postgresql://YOUR_USERNAME@localhost:5432/zigzag"
# Optional for production-style migration workflows.
DIRECT_URL="postgresql://YOUR_USERNAME@localhost:5432/zigzag"
NODE_ENV=development

NEXTAUTH_URL=http://localhost:3069
NEXTAUTH_SECRET=your-secret-key-here

# Vercel Blob — required for Company logo uploads (dashboard + API)
BLOB_READ_WRITE_TOKEN=

# Playwright E2E (authenticated specs)
E2E_EMAIL=
E2E_PASSWORD=
# Optional: run Playwright against production build (recommended for auth-heavy specs)
# PLAYWRIGHT_USE_PROD=1 npm run test:e2e -- e2e/mobile-sticky-navbar.spec.ts
