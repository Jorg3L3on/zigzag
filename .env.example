# Copy to `.env` and adjust values. Never commit `.env`.
#
# PostgreSQL: create the database first (e.g. `createdb zigzag`).
# Homebrew Postgres typically uses your macOS username and no password in the URL.

DATABASE_URL="postgresql://YOUR_USERNAME@localhost:5432/zigzag"
NODE_ENV=development

NEXTAUTH_URL=http://localhost:3069
NEXTAUTH_SECRET=your-secret-key-here
