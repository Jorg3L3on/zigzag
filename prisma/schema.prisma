// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Service {
  id          Int       @id @default(autoincrement())
  name        String
  description String
  price       Float
  created_at  DateTime  @default(now())
  updated_at  DateTime?
  deleted_at  DateTime?

  services_tickets ServicesTickets[]
  company_id       Int?

  company Company? @relation(fields: [company_id], references: [id])

  @@index([company_id])
}

model Client {
  id         Int       @id @default(autoincrement())
  name       String
  email      String?   @db.VarChar(100)
  phone      String?   @db.VarChar(20)
  document   String?   @db.VarChar(100)
  address    String?
  created_at DateTime  @default(now())
  updated_at DateTime?
  deleted_at DateTime?
  company_id Int?

  company Company? @relation(fields: [company_id], references: [id])
  tickets Ticket[]

  @@index([company_id])
}

model Ticket {
  id               BigInt            @id @default(autoincrement())
  client_id        Int?
  client_name      String?           @db.VarChar(100)
  client_tel       String?           @db.VarChar(10)
  ticket_date      DateTime?
  total            Float?            @db.DoublePrecision
  paid             Float?            @db.DoublePrecision
  email            String?           @db.VarChar(40)
  finished         Boolean           @default(false)
  document         String?           @db.VarChar(100)
  created_at       DateTime          @default(now())
  updated_at       DateTime?
  deleted_at       DateTime?
  services_tickets ServicesTickets[]
  company_id       Int?

  company Company? @relation(fields: [company_id], references: [id])
  client  Client?  @relation(fields: [client_id], references: [id])
  User    User?    @relation(fields: [userId], references: [id])
  userId  BigInt?

  @@index([company_id])
  @@index([client_id])
}

model ServicesTickets {
  id         Int       @id @default(autoincrement())
  service_id Int
  ticket_id  BigInt
  quantity   Int
  price      Float
  created_at DateTime  @default(now())
  updated_at DateTime?
  deleted_at DateTime?

  service Service @relation(fields: [service_id], references: [id])
  ticket  Ticket  @relation(fields: [ticket_id], references: [id])

  @@index([service_id])
  @@index([ticket_id])
}

model Role {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  created_at  DateTime  @default(now())
  updated_at  DateTime?
  deleted_at  DateTime?
  company_id  Int?

  company     Company?         @relation(fields: [company_id], references: [id])
  users       User[]
  permissions RolePermission[]

  @@index([company_id])
}

model Permission {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  created_at  DateTime  @default(now())
  updated_at  DateTime?
  deleted_at  DateTime?
  company_id  Int?

  company Company?         @relation(fields: [company_id], references: [id])
  roles   RolePermission[]

  @@index([company_id])
}

model RolePermission {
  role_id       Int
  permission_id Int
  created_at    DateTime @default(now())

  role       Role       @relation(fields: [role_id], references: [id])
  permission Permission @relation(fields: [permission_id], references: [id])

  @@id([role_id, permission_id])
  @@index([role_id])
  @@index([permission_id])
}

model User {
  id                BigInt    @id @default(autoincrement())
  name              String
  email             String    @unique
  email_verified_at DateTime?
  password          String
  remember_token    String?
  created_at        DateTime  @default(now())
  updated_at        DateTime?
  deleted_at        DateTime?
  company_id        Int?
  role_id           Int?

  company Company? @relation(fields: [company_id], references: [id])
  role    Role?    @relation(fields: [role_id], references: [id])
  tickets Ticket[]

  @@index([company_id])
  @@index([role_id])
}

model Company {
  id         Int       @id @default(autoincrement())
  name       String
  address    String
  phone      String
  email      String
  logo       String?
  is_system  Boolean   @default(false)
  created_at DateTime  @default(now())
  updated_at DateTime?
  deleted_at DateTime?

  services   Service[]
  users      User[]
  tickets    Ticket[]
  Client     Client[]
  Role       Role[]
  Permission Permission[]

  @@unique([name])
}
